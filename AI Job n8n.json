        "jsCode": "const jobs = $input.all().map(item => item.json);\n\nreturn jobs.map(job => ({\n  json: {\n    id:          job.id || String(Math.random()),\n    title:       job.title || '',\n    company:     job.companyName || '',\n    location:    job.location || '',\n    salary:      job.salary || 'Not specified',\n    url:         job.jobUrl || '',\n    description: (job.description || '')\n      .replace(/<[^>]*>/g, ' ')\n      .replace(/\\s+/g, ' ')\n      .trim()\n      .slice(0, 800)\n  }\n}));"

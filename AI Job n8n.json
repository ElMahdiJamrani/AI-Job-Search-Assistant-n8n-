    {
      "parameters": {
        "jsCode": "const results = [];\nfor (const item of $input.all()) {\n  const content = item.json.choices[0].message.content;\n\n  let ai = { summary: '', skills: [], score: 0, reason: '', years_experience: 0 };\n  try { ai = JSON.parse(content); } \n  catch(e) { ai.summary = content; }\n\n  results.push({\n    json: {\n      title:              $('If').item.json.title,\n      company:            $('If').item.json.company,\n      location:           $('If').item.json.location,\n      salary:             $('If').item.json.salary,\n      url:                $('If').item.json.url,\n      summary:            ai.summary            || '',\n      skills:             (ai.skills            || []).join(', '),\n      score:              ai.score              || 0,\n      reason:             ai.reason             || '',\n      years_experience:   ai.years_experience   || 0\n    }\n  });\n}\n\nreturn results;"
      },

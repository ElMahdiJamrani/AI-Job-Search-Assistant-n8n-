        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a job search assistant. Return ONLY valid JSON with: summary (2 sentences), skills (array of top 5), score (0-100), reason (1 sentence), years_experience (number, minimum years required, use 0 if not mentioned or if entry level). No markdown, no extra text.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Title: {{ $json.title }}\\nCompany: {{ $json.company }}\\nDescription: {{ $json.description }}\"\n    }\n  ],\n  \"temperature\": 0.3\n}",
